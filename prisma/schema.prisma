generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
}

enum CheckInMethod {
  QR_CODE
  MANUAL_CODE
}

enum CheckInLogStatus {
  SUCCESS
  ALREADY_CHECKED_IN
  NOT_FOUND
  INVALID
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
  REFUNDED
}

enum PaymentProduct {
  EVENT_CREDIT
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  eventCredits Int       @default(0)
  events       Event[]   @relation("EventCreator")
  payments     Payment[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Event {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  description   String?
  startAt       DateTime
  endAt         DateTime?
  location      String?
  attendeeLimit Int?
  paymentId     String?      @unique
  payment       Payment?     @relation("EventPayment", fields: [paymentId], references: [id], onDelete: SetNull)
  createdById   String
  createdBy     User         @relation("EventCreator", fields: [createdById], references: [id])
  attendees     Attendee[]
  checkInLogs   CheckInLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Attendee {
  id            String        @id @default(cuid())
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  phone         String
  checkInCode   String
  qrToken       String
  checkInStatus CheckInStatus @default(NOT_CHECKED_IN)
  checkedInAt   DateTime?
  checkInLogs   CheckInLog[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([eventId, checkInCode])
  @@unique([eventId, qrToken])
  @@index([eventId, name])
  @@index([eventId, phone])
}

model CheckInLog {
  id          String           @id @default(cuid())
  eventId     String
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeId  String?
  attendee    Attendee?        @relation(fields: [attendeeId], references: [id], onDelete: SetNull)
  method      CheckInMethod
  status      CheckInLogStatus
  checkedInAt DateTime?
  createdAt   DateTime         @default(now())

  @@index([eventId, createdAt])
  @@index([attendeeId])
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String         @default("newebpay")
  product         PaymentProduct @default(EVENT_CREDIT)
  status          PaymentStatus  @default(PENDING)
  quantity        Int            @default(1)
  creditsGranted  Int            @default(0)
  amountTotal     Int?
  currency        String?        @default("TWD")
  pricingTier     String?
  attendeeLimit   Int?
  providerOrderNo String?        @unique
  providerTradeNo String?        @unique
  checkoutUrl     String?
  event           Event?         @relation("EventPayment")
  consumedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([consumedAt])
}
