generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
}

enum CheckInMethod {
  QR_CODE
  MANUAL_CODE
  PHONE
}

enum CheckInLogStatus {
  SUCCESS
  ALREADY_CHECKED_IN
  NOT_FOUND
  INVALID
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELED
  FAILED
  REFUNDED
}

enum PaymentProduct {
  EVENT_CREDIT
  ATTENDEE_CREDIT
}

enum Gender {
  M
  F
  OTHER
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String
  role            UserRole  @default(ADMIN)
  attendeeCredits Int       @default(0)
  assignedEventId String?
  assignedEvent   Event?    @relation("EventStaff", fields: [assignedEventId], references: [id], onDelete: SetNull)
  events          Event[]   @relation("EventCreator")
  payments        Payment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Event {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  description          String?
  content              String?
  startAt              DateTime
  endAt                DateTime?
  location             String?
  attendeeLimit        Int?
  registrationRequired Boolean      @default(false)
  venueCode            String       @default(uuid())
  registrationFields   Json         @default("[]")
  createdById          String
  createdBy            User         @relation("EventCreator", fields: [createdById], references: [id])
  attendees            Attendee[]
  checkInLogs          CheckInLog[]
  survey               Survey?
  staffMembers         User[]       @relation("EventStaff")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model Attendee {
  id              String           @id @default(cuid())
  eventId         String
  event           Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  email           String?
  age             Int?
  gender          Gender?
  checkInCode     String
  qrToken         String
  checkInStatus   CheckInStatus    @default(NOT_CHECKED_IN)
  checkedInAt     DateTime?
  customFields    Json?
  checkInLogs     CheckInLog[]
  surveyResponses SurveyResponse[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([eventId, checkInCode])
  @@unique([eventId, qrToken])
  @@index([eventId, name])
  @@index([eventId, phone])
}

model CheckInLog {
  id          String           @id @default(cuid())
  eventId     String
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendeeId  String?
  attendee    Attendee?        @relation(fields: [attendeeId], references: [id], onDelete: SetNull)
  method      CheckInMethod
  status      CheckInLogStatus
  checkedInAt DateTime?
  createdAt   DateTime         @default(now())

  @@index([eventId, createdAt])
  @@index([attendeeId])
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        String         @default("newebpay")
  product         PaymentProduct @default(ATTENDEE_CREDIT)
  status          PaymentStatus  @default(PENDING)
  quantity        Int            @default(1)
  creditsGranted  Int            @default(0)
  amountTotal     Int?
  currency        String?        @default("TWD")
  pricingTier     String?
  attendeeLimit   Int?
  providerOrderNo String?        @unique
  providerTradeNo String?        @unique
  checkoutUrl     String?
  consumedAt      DateTime?
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, createdAt])
  @@index([status])
  @@index([consumedAt])
}

model Survey {
  id        String           @id @default(cuid())
  eventId   String           @unique
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String           @default("活動問卷")
  sentAt    DateTime?
  questions SurveyQuestion[]
  responses SurveyResponse[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SurveyQuestion {
  id       String   @id @default(cuid())
  surveyId String
  survey   Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question String
  type     String   @default("text")
  options  String[]
  order    Int      @default(0)
}

model SurveyResponse {
  id         String    @id @default(cuid())
  surveyId   String
  survey     Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  attendeeId String?
  attendee   Attendee? @relation(fields: [attendeeId], references: [id], onDelete: SetNull)
  answers    Json
  createdAt  DateTime  @default(now())

  @@index([surveyId])
  @@index([attendeeId])
}
