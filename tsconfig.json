{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@monmate/types": ["packages/types/src/index.ts"],
      "@monmate/utils": ["packages/utils/src/index.ts"]
    },
    "types": ["node"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "api/**/*.ts"]
}
